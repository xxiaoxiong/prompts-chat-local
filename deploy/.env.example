# prompts.chat deployment environment
# Copy this file to .env and fill in the real values.

# PostgreSQL password used by both db and app services
POSTGRES_PASSWORD=change-this-password

# Generate with: openssl rand -base64 32
AUTH_SECRET=change-this-auth-secret

# Host port exposed by Docker Compose
PORT=4444

# Public URL used by Auth.js / NextAuth
# Examples:
# APP_URL=http://172.16.80.250:4444
# APP_URL=https://your-domain.com
APP_URL=http://172.16.80.250:4444

# Intranet anonymous write mode
# Set to true only in trusted internal networks
ALLOW_ANONYMOUS_WRITE=false
